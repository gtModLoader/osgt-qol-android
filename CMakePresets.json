{
  "version": 3,
  "configurePresets": [
    {
      "name": "android-arm64",
      "generator": "Ninja",
      "binaryDir": "build/arm64",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK}/build/cmake/android.toolchain.cmake",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-21",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "DEVELOPMENT_BUILD": "ON"
      }
    }
  ]
}